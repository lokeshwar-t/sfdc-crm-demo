    {
      "key": "base_url",
      "value": "http://localhost:5050"
    },
    {
      "key": "agent_token",
      "value": "refold-demo-agent-token"
    },
    {
      "key": "login_email",
      "value": "ceo@cloudvision.com"
    },
    {
      "key": "login_password",
      "value": "demo123"
    },
