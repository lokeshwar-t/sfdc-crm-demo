# Copy to .env for local development and fill in real values.
# .env is gitignored — never commit real secrets. In production (Railway/Render)
# set these in the host's dashboard/secret store, not in a file.

# --- Refold (Cobalt) workflow integration ---
REFOLD_API_KEY=            # Cobalt X-API-Key (SECRET)
REFOLD_LINKED_ACCOUNT_ID=  # Cobalt linked_account_id

# Optional overrides (defaults live in config.py):
# REFOLD_API_BASE=https://cobalt-skc.uscentral1.gocobalt.io
# REFOLD_MEETING_PREP_WORKFLOW_ID=6a5f73903284520f7515020f
# REFOLD_MEETING_PREP_SLUG=Coba-8517
# REFOLD_CONFIG_ID=

# Renewal agent — set once its Cobalt workflow exists:
# REFOLD_RENEWAL_WORKFLOW_ID=
# REFOLD_RENEWAL_SLUG=

# Churn Sentinel agent — set once its Cobalt workflow exists:
# REFOLD_CHURN_WORKFLOW_ID=
# REFOLD_CHURN_SLUG=

# Briefing agent — set once its Cobalt workflow exists:
# REFOLD_BRIEFING_WORKFLOW_ID=
# REFOLD_BRIEFING_SLUG=

# Pipeline Hygiene agent — set once its Cobalt workflow exists:
# REFOLD_PIPELINE_WORKFLOW_ID=
# REFOLD_PIPELINE_SLUG=

# Forecast agent — set once its Cobalt workflow exists:
# REFOLD_FORECAST_WORKFLOW_ID=
# REFOLD_FORECAST_SLUG=

# --- App ---
